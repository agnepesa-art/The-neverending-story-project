wd:Q1077745 a schema:Person ; 
    rdfs:label "Fictional character" ;
    schema:name "Bastian Balthazar Bux"@de ;
    schema:alternateName "Bastian Balthasar Bux"@en ;
    schema:alternateName "Bastiano Baldassarre Bucci"@it ;
    dcterms:description "Main character of the The neverending story. While reading the book he stole a library, he finds himself as a character inside the story. In the pages following the one encoded later, he is called inside the book in order to save Fantasia and his people" . 

wd:Q8100750 a schema:Person ; 
    rdfs:label "Fictional character" ;
    schema:name "Kindliche Kaiserin"@de ;
    schema:alternateName "Childlike Empress"@en ;
    schema:alternateName "Infanta Imperatrice"@it ;
    dcterms:description "Empress of Fantasia, in the page encoded she is climbing the steps towards the Old Man of the Wandering Mountain seeking to call Bastian into her world and save it by giving her a new name" . 

wd:Q58100675 a schema:Person ; 
    rdfs:label "Fictional character" ;
    schema:name "Alte vom Wandernden Berge"@de ;
    schema:alternateName "Old Man of Wandering Mountain"@en ;
    schema:alternateName "Vecchio della Montagna Vagante"@it ;
    dcterms:description "Guardian of the book of life in which is written the entire story of Fantasia and his people. This book appears in page 195 and is described with the same phisical characteristics as The neverending story volume in his original edition" . 

tnse:alphabet a skos:Concept ; 
    skos:prefLabel "alphabet" ; 
    dcterms:description "alphabet motif recurrent throughout the text, reference to combinatory literature, literary genre that uses the properties of language in a playful way" . 

tnse:metanarration a skos:Concept ; 
    skos:prefLabel "metanarration" ; 
    dcterms:description "theme of the metanarration, the book that the extradiegetic reader is reading is the same book that Bastiano is reading and the same in the story inside the fictional book" . 

